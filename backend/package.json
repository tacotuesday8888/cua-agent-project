{
  "name": "macautopilot-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:rules": "FIREBASE_RULES_TEST=1 vitest run test/firebaseRules.test.ts",
    "test:rules:emulator": "cd .. && npx --yes firebase-tools@15.21.0 emulators:exec --project demo-macautopilot-rules --only firestore,database,storage \"npm --prefix backend run test:rules\""
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.38.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.37.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^26.0.1",
    "firebase": "^12.15.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "uuid": "11.1.1",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-zipkin": "2.8.0",
    "@opentelemetry/otlp-exporter-base": "0.219.0",
    "@opentelemetry/otlp-grpc-exporter-base": "0.219.0",
    "@opentelemetry/otlp-transformer": "0.219.0",
    "@opentelemetry/propagator-b3": "2.8.0",
    "@opentelemetry/propagator-jaeger": "2.8.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/sdk-trace-node": "2.8.0"
  }
}
