rules_version = '2';

// The client never accesses Firestore directly — the authenticated Cloud
// Function (Admin SDK, which bypasses these rules) mediates all access. Deny all
// direct client access by default. Add owner-scoped rules here only if/when the
// app needs direct reads.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
